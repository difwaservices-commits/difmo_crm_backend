<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e2e8f0; border-radius: 12px; }
        .header { text-align: center; padding-bottom: 20px; border-bottom: 2px solid #3b82f6; }
        .content { padding: 20px 0; }
        .footer { font-size: 12px; text-align: center; color: #718096; margin-top: 20px; }
        .status { font-weight: bold; color: #2563eb; text-transform: capitalize; }
        .details { background: #f8fafc; padding: 15px; border-radius: 8px; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>Leave Application Update</h2>
        </div>
        <div class="content">
            <p>Hello <strong>{{name}}</strong>,</p>
            <p>Your leave application status has been updated to: <span class="status">{{status}}</span></p>
            
            <div class="details">
                <p><strong>Period:</strong> {{startDate}} to {{endDate}}</p>
                {{#if comment}}
                <p><strong>Admin Note:</strong> {{comment}}</p>
                {{/if}}
            </div>
            
            <p>If you have any questions, please contact the HR department.</p>
        </div>
        <div class="footer">
            <p>This is an automated message from the CRM System.</p>
        </div>
    </div>
</body>
</html>
